# osint-pipeline/.env.example
#
# ╔══════════════════════════════════════════════════════════════╗
# ║           OSINT PIPELINE — КОНФІГУРАЦІЯ                     ║
# ║  Скопіюй цей файл у .env і заповни своїми даними            ║
# ║  НІКОЛИ не комітити .env у git!                             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── ДОМЕНИ ──────────────────────────────────────────────────────
# Один або декілька через кому
# Формат: example.com, sub.example.com, another-site.org
TARGET_DOMAINS=

# ── EMAIL АДРЕСИ ────────────────────────────────────────────────
# Один або декілька через кому
# Формат: john@example.com, jane@test.com
TARGET_EMAILS=

# ── IP АДРЕСИ ───────────────────────────────────────────────────
# IPv4 та IPv6, один або декілька через кому
# Формат: 8.8.8.8, 1.1.1.1, 2001:4860:4860::8888
TARGET_IPS=

# ── ТЕЛЕФОНИ ────────────────────────────────────────────────────
# Міжнародний формат з кодом країни, один або декілька через кому
# Формат: +380991234567, +12025551234
TARGET_PHONES=


# ╔══════════════════════════════════════════════════════════════╗
# ║                      API КЛЮЧІ                              ║
# ╚══════════════════════════════════════════════════════════════╝

# Shodan — порти, сервіси, банери, вразливості
# Отримати: https://account.shodan.io/
SHODAN_API_KEY=

# HaveIBeenPwned — перевірка витоків по email
# Отримати: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Hunter.io — email harvesting по домену
# Отримати: https://hunter.io/api-keys
HUNTER_API_KEY=

# VirusTotal — репутація доменів та IP
# Отримати: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=


# ╔══════════════════════════════════════════════════════════════╗
# ║                    НАЛАШТУВАННЯ                             ║
# ╚══════════════════════════════════════════════════════════════╝

# Шлях до виконуваного файлу recon-ng
RECON_NG_PATH=/usr/local/bin/recon-ng

# Назва workspace в recon-ng (буде створено автоматично)
WORKSPACE=osint_workspace

# Директорія для збереження звітів
OUTPUT_DIR=./reports

# Рівень логування: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Таймаут для кожного модуля (секунди)
MODULE_TIMEOUT=60
